{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "SimpleNet",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "/mnt/T19/anaconda3/envs/SimpleNet_env/bin/python",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "CUDA_VISIBLE_DEVICES": "2"
            },
            "args": [
                "--gpu", "0",
                "--seed", "0",
                "--log_group", "simplenet_mvtec",
